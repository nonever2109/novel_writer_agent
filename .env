# PROVIDER
PROVIDER=openai_compatible

# OpenAI official API
OPENAI_API_KEY=
OPENAI_MODEL=

# OpenAI-compatible providers
COMPAT_API_KEY=
COMPAT_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
COMPAT_MODEL=qwen3.5-flash

# Debugging
LLM_TRACE=true
LLM_TRACE_MAX_CHARS=6000
LLM_TIMEOUT_SECONDS=300
LLM_PROGRESS=true
LLM_FALLBACK_ON_ERROR=true

# Agent Runtime
NOVEL_MEMORY_DIR=projects/default/story_memory
NOVEL_OUTPUT_DIR=projects/default/outputs
NOVEL_PROJECTS_INDEX=novel_projects.json